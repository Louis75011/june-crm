# ============================================
# June Lab CRM — Variables d'environnement
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# ===== SERVEUR =====
PORT=3001
NODE_ENV=development

# ===== BREVO (ex-Sendinblue) — Transactional Email =====
# API key Brevo (v3) : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXX
# ID de la liste de contacts où stocker les prospects
BREVO_LIST_ID=
# Email expéditeur des notifications (doit être vérifié dans Brevo)
BREVO_SENDER_EMAIL=crm@junelabs.fr
BREVO_SENDER_NAME=June Lab CRM
# Template IDs Brevo pour les emails automatiques
BREVO_TEMPLATE_CONFIRMATION=
BREVO_TEMPLATE_RELANCE=
# Webhook secret pour valider les callbacks Brevo
BREVO_WEBHOOK_SECRET=

# ===== GOOGLE ANALYTICS 4 — Measurement Protocol =====
# ID de mesure GA4 (format: G-XXXXXXXXXX)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Secret API pour le Measurement Protocol (Admin > Data Streams > Measurement Protocol)
GA4_API_SECRET=
# ID de flux de données
GA4_STREAM_ID=

# ===== META PIXEL — Conversions API =====
META_PIXEL_ID=
META_ACCESS_TOKEN=

# ===== MICROSOFT CLARITY =====
CLARITY_PROJECT_ID=

# ===== VERCEL — Déploiement =====
# Auto-injecté par Vercel, pas besoin de le définir manuellement
# VERCEL_URL=

# ===== RGPD / SÉCURITÉ =====
# Clé secrète pour le chiffrement des données sensibles (optionnel, pour phase 2)
ENCRYPTION_SECRET=
# Durée de rétention des prospects en jours (RGPD)
DATA_RETENTION_DAYS=365
